---
import MerchCarousel from "./MerchCarousel";
---
<div class="relative w-full flex flex-col items-center -mt-16 lg:-mt-20">
  <!-- Product Images -->
  <div class="hidden sm:flex items-end justify-center w-full max-w-4xl">
    <!-- Left Image -->
    <a href="https://shop.talkinsecret.com" class="w-2/5 transform translate-y-8 transition-transform duration-300 hover:scale-105 hover:translate-y-6">
      <img
        class="w-full transition-all duration-300 hover:brightness-110"
        src="/images/unisex-classic-tee-forest-green-front-and-back-67c24e797e636.webp"
        alt="Stranger In Disguise T-Shirt"
        width="1000"
        height="1000"
        loading="lazy"
      />
    </a>
    <!-- Center Image (Larger) -->
    <a href="https://shop.talkinsecret.com" class="w-3/5 z-10 transition-transform duration-300 hover:scale-105">
      <img
        class="w-full transition-all duration-300 hover:brightness-110"
        src="/images/unisex-classic-tee-maroon-front-67c224fee35f1.webp"
        alt="Petrichor T-Shirt"
        width="1000"
        height="1000"
        loading="lazy"
      />
    </a>
    <!-- Right Image -->
    <a href="https://shop.talkinsecret.com" class="w-2/5 transform translate-y-8 transition-transform duration-300 hover:scale-105 hover:translate-y-6">
      <img
        class="w-full transition-all duration-300 hover:brightness-110"
        src="/images/unisex-classic-tee-black-front-2-67c238a3f2131.webp"
        alt="Talkin Secret T-Shirt"
        width="1000"
        height="1000"
        loading="lazy"
      />
    </a>
  </div>

  <!-- Mobile Layout: Carousel -->
  <div class="sm:hidden w-full">
    <MerchCarousel client:load />
  </div>

  <!-- Call to Action (Desktop only - Mobile hat es im Carousel) -->
  <div class="hidden sm:flex flex-col items-center justify-center w-full max-w-2xl mt-8 lg:mt-6 mb-auto text-center">
    <p class="text-2xl font-semibold mb-4">Support the noise - Wear the merch!</p>
    <a href="https://shop.talkinsecret.com" target="_blank" rel="noopener noreferrer">
      <button class="bg-primary hover:bg-background hover:border-primary hover:border-solid border-solid border-2 border-primary hover:border-2 text-white rounded-none px-16 py-6 font-semibold transition-colors">Shop</button>
    </a>
  </div>
</div>
