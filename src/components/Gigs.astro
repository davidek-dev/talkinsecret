---
import {
  Table,
  TableBody,
  TableCaption,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
import { Button } from "@/components/ui/button";
---

<div class="w-full max-w-4xl mx-auto px-2 sm:px-4 overflow-x-auto">
  <Table>
    <TableCaption className="pt-8 text-base sm:text-lg lg:text-xl mt-2">Your town ain't on the list? Leave us a message <a href="#contact" class="text-secondary font-bold">here!</a></TableCaption>
    <TableHeader>
      <TableRow className="text-sm sm:text-xl">
        <TableHead>Date</TableHead>
        <TableHead>Venue / Event</TableHead>
        <TableHead>City</TableHead>
        <TableHead>Link</TableHead>
      </TableRow>
    </TableHeader>
    <tbody id="gigs-tbody" class="text-xs sm:text-lg [&_tr:last-child]:border-0">
      <tr>
        <td colspan="4" class="p-4 align-middle text-center">Loading upcoming gigs...</td>
      </tr>
    </tbody>
  </Table>
</div>

<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const tbody = document.getElementById('gigs-tbody');
    if (!tbody) return;

    try {
      const response = await fetch('/.netlify/functions/get-gigs');
      if (!response.ok) {
        throw new Error(`Network response was not ok: ${response.statusText}`);
      }
      const gigs = await response.json();

      // Clear loading state - use DOM manipulation instead of innerHTML
      while (tbody.firstChild) {
        tbody.removeChild(tbody.firstChild);
      }

      if (gigs.length === 0) {
        const row = document.createElement('tr');
        const cell = document.createElement('td');
        cell.setAttribute('colspan', '4');
        cell.className = 'text-center';
        cell.textContent = 'No upcoming gigs at the moment. Check back soon!';
        row.appendChild(cell);
        tbody.appendChild(row);
      } else {
        gigs.forEach((gig: { date: string; venue: string; city: string; ticketsUrl: string }) => {
          const row = document.createElement('tr');
          row.className = 'TableRow'; // Use the appropriate class for styling

          const dateCell = document.createElement('td');
          dateCell.className = 'TableCell';
          dateCell.textContent = new Date(gig.date).toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' });
          row.appendChild(dateCell);

          const venueCell = document.createElement('td');
          venueCell.className = 'TableCell';
          venueCell.textContent = gig.venue;
          row.appendChild(venueCell);

          const cityCell = document.createElement('td');
          cityCell.className = 'TableCell';
          cityCell.textContent = gig.city;
          row.appendChild(cityCell);

          const linkCell = document.createElement('td');
          linkCell.className = 'TableCell';
          if (gig.ticketsUrl) {
            const link = document.createElement('a');
            link.href = gig.ticketsUrl;
            link.target = '_blank';
            link.rel = 'noopener noreferrer';

            const button = document.createElement('button');
            // Apply classes from your Button component. This is a simplification.
            // For full component styles, you might need a more complex setup or use utility classes.
            button.className = 'px-2 py-1 sm:px-4 sm:py-2 text-xs sm:text-base bg-primary text-primary-foreground hover:bg-primary/90 rounded-md';
            button.textContent = 'Tickets';
            
            link.appendChild(button);
            linkCell.appendChild(link);
          } else {
            linkCell.textContent = 'N/A';
          }
          row.appendChild(linkCell);

          tbody.appendChild(row);
        });
      }
    } catch (error) {
      console.error('Error loading gigs:', error);
      if (tbody) {
        // Clear existing content using DOM manipulation
        while (tbody.firstChild) {
          tbody.removeChild(tbody.firstChild);
        }
        
        // Create error message using DOM methods
        const row = document.createElement('tr');
        const cell = document.createElement('td');
        cell.setAttribute('colspan', '4');
        cell.className = 'text-center text-red-500 p-4';
        cell.textContent = 'Failed to load gigs. Please try again later.';
        row.appendChild(cell);
        tbody.appendChild(row);
      }
    }
  });
</script>

