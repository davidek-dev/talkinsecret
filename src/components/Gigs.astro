---
import {
  Table,
  TableCaption,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table";
---

<div class="w-full max-w-4xl mx-auto px-2 sm:px-4 overflow-x-auto">
  <Table>
    <TableCaption className="pt-8 text-base sm:text-lg lg:text-xl mt-2">Your town ain't on the list? Leave us a message <a href="#contact" class="text-secondary font-bold">here!</a></TableCaption>
    <TableHeader>
      <TableRow className="text-sm sm:text-xl">
        <TableHead>Date</TableHead>
        <TableHead>Venue / Event</TableHead>
        <TableHead>City</TableHead>
        <TableHead>Link</TableHead>
      </TableRow>
    </TableHeader>
    <tbody id="gigs-tbody" class="text-xs sm:text-lg [&_tr:last-child]:border-0">
      <tr>
        <td colspan="4" class="p-4 align-middle text-center">Loading upcoming gigs...</td>
      </tr>
    </tbody>
  </Table>
</div>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    const tbodyEl = document.getElementById('gigs-tbody');
    if (!tbodyEl) return;

    const REFRESH_MS = 15 * 60 * 1000; // 15 Minuten

    function clearBody() {
      while (tbodyEl.firstChild) tbodyEl.removeChild(tbodyEl.firstChild);
    }

    function render(gigsArray) {
      clearBody();
      if (!Array.isArray(gigsArray) || gigsArray.length === 0) {
        const row = document.createElement('tr');
        const cell = document.createElement('td');
        cell.setAttribute('colspan', '4');
        cell.className = 'text-center';
        cell.textContent = 'No upcoming gigs at the moment. Check back soon!';
        row.appendChild(cell);
        tbodyEl.appendChild(row);
        return;
      }

      const rowBase = 'border-b transition-colors hover:bg-muted/50';
      // Slightly tighter spacing than before
      const cellBase = 'p-2.5 sm:p-3 align-middle';

      gigsArray.forEach((gig) => {
        const row = document.createElement('tr');
        row.className = rowBase;

        const dateCell = document.createElement('td');
        dateCell.className = cellBase;
        dateCell.textContent = new Date(gig.date).toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' });
        row.appendChild(dateCell);

        const venueCell = document.createElement('td');
        venueCell.className = cellBase;
        venueCell.textContent = gig.venue || '';
        row.appendChild(venueCell);

        const cityCell = document.createElement('td');
        cityCell.className = cellBase;
        cityCell.textContent = gig.city || '';
        row.appendChild(cityCell);

        const linkCell = document.createElement('td');
        linkCell.className = cellBase;
        if (gig.ticketsUrl) {
          const link = document.createElement('a');
          link.href = gig.ticketsUrl;
          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          const button = document.createElement('button');
          button.className = 'px-2.5 py-1 sm:px-3 sm:py-1.5 text-xs sm:text-base bg-primary text-primary-foreground hover:bg-primary/90 rounded-md';
          button.textContent = 'Tickets';
          link.appendChild(button);
          linkCell.appendChild(link);
        } else {
          linkCell.textContent = 'N/A';
        }
        row.appendChild(linkCell);

        tbodyEl.appendChild(row);
      });
    }

    async function load() {
      try {
        const response = await fetch('/.netlify/functions/get-gigs', { cache: 'no-store' });
        if (!response.ok) throw new Error(`Network response was not ok: ${response.status} ${response.statusText}`);
  let gigs = await response.json();

        // Defensiv: Vergangene Events clientseitig zusätzlich filtern (Datum ab heute 00:00)
        const todayStart = new Date();
        todayStart.setHours(0, 0, 0, 0);
        gigs = (Array.isArray(gigs) ? gigs : []).filter((g) => {
          const d = g?.date ? new Date(g.date) : null;
          return d && d.getTime() >= todayStart.getTime();
        });

        render(gigs);
      } catch (error) {
        console.error('Error loading gigs:', error);
        clearBody();
        const row = document.createElement('tr');
        const cell = document.createElement('td');
        cell.setAttribute('colspan', '4');
        cell.className = 'text-center text-red-500 p-4';
        cell.textContent = 'Failed to load gigs. Please try again later.';
        row.appendChild(cell);
        tbodyEl.appendChild(row);
      }
    }

    // Initial load and periodic refresh
    load();
    setInterval(load, REFRESH_MS);
  });
</script>

