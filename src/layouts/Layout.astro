---
import CookieConsent from "../components/CookieConsent.astro";
import '../styles/responsive-utilities.css';

// Erweitere die Props für dynamische SEO-Daten
interface Props {
  title: string;
  description: string; // Jede Seite braucht eine eigene Beschreibung
  canonicalURL: URL;   // Jede Seite braucht ihre eigene Canonical URL
  image?: string;     // Optional: Ein spezielles Bild für Unterseiten
  bodyClass?: string;
}

const {
  title,
  description,
  canonicalURL, // Wir verwenden diese jetzt statt eines festen Links
  image = "/images/og-image-talkin-secret.jpg", // Standard-Bild, falls keins übergeben wird
  bodyClass = "",
} = Astro.props;

// Erstelle den Seitentitel nach einem konsistenten Muster
const pageTitle = `${title} | Talkin' Secret`;
---

<!doctype html>
<html lang="en-GB" dir="ltr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

  <title>{pageTitle}</title>

  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <meta name="author" content="Talkin' Secret" />
  <meta name="robots" content="index, follow" />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#000000" />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:image:alt" content={`Image for ${title}`} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Talkin' Secret" />
  <meta property="og:locale" content="en_GB" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />
  <meta name="twitter:image:alt" content={`Image for ${title}`} />
  <meta name="twitter:site" content="@talkinsecret" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  
  <script type="application/ld+json" is:inline>

{
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  "name": "Talkin' Secret",
  "alternateName": [
    "talkin secret band", 
    "talking secret", 
    "talkin secrets", 
    "talking secrets"
  ],
  "description": "Talkin' Secret is a four-piece Britpop/Post-Punk band from Hamburg, Germany. Founded in 2022, their sound is heavily influenced by UK acts like Oasis, The Smiths, and modern post-punk bands such as Fontaines D.C. and The Murder Capital. Their music captures a raw energy, blending themes of longing (Sehnsucht), nostalgia, and the unfiltered experience of life. Their debut album 'Petrichor' was released in 2025.",
  "genre": ["Britpop", "Post-Punk", "Indie Rock"],
  "url": "https://talkinsecret.com/",
  "logo": "https://talkinsecret.com/images/logo.png",
  "image": "https://talkinsecret.com/images/og-image-talkin-secret.jpg",
  "foundingDate": "2022",
  "foundingLocation": {
    "@type": "City",
    "name": "Hamburg",
    "sameAs": "https://en.wikipedia.org/wiki/Hamburg"
  },
  "member": [
    {
      "@type": "Person",
      "name": "Marti",
      "roleName": ["Lead Vocals", "Rhythm Guitar"]
    },
    {
      "@type": "Person",
      "name": "Lina",
      "roleName": "Lead Guitar"
    },
    {
      "@type": "Person",
      "name": "Ole",
      "roleName": ["Bass", "Backing Vocals"]
    },
    {
      "@type": "Person",
      "name": "Nick",
      "roleName": "Drums"
    }
  ],
  "album": {
    "@type": "MusicAlbum",
    "name": "Petrichor",
    "byArtist": {
      "@type": "MusicGroup",
      "name": "Talkin' Secret"
    },
    "datePublished": "2025-02-14",
    "numTracks": 9,
    "track": [
      {"@type": "MusicRecording", "name": "Petrichor"},
      {"@type": "MusicRecording", "name": "Worth The Way"},
      {"@type": "MusicRecording", "name": "Come On"},
      {"@type": "MusicRecording", "name": "Changes"},
      {"@type": "MusicRecording", "name": "Stranger In Disguise"},
      {"@type": "MusicRecording", "name": "Glimpse Of The Morning"},
      {"@type": "MusicRecording", "name": "Miracles"},
      {"@type": "MusicRecording", "name": "Only Friend"},
      {"@type": "MusicRecording", "name": "Somehow Somewhere"}
    ]
  },
  "sameAs": [
    "https://open.spotify.com/intl-de/artist/1MdTDN4vXdIXvmTMn3pLjQ",
    "https://music.apple.com/de/artist/talkin-secret/1763604270",
    "https://music.amazon.de/artists/B0DDL9HMW3/talkin'-secret",
    "https://www.deezer.com/de/artist/278486001",
    "https://music.youtube.com/channel/UCgpNvup1NeKna2lFet805LQ",
    "https://www.instagram.com/talkinsecret/",
    "https://www.tiktok.com/@talkinsecret",
    "https://www.threads.net/@talkinsecret"
  ]
}
</script>
  <script src="/src/js/cursor-init.js"></script>
  <script src="/src/js/ios-viewport-fix.js"></script>

  <link rel="preload" href="/fonts/LibreBaskerville-Regular.ttf" as="font" type="font/ttf" crossorigin />
  </head>
  
  <body class={`${bodyClass} antialiased`}>
	  <div class="cursor"></div>

    <script>
      // Stylischer Browser-Console-Prompt für Dave 'The Tank' Zeplin (modern, auffällig)
      window.addEventListener("DOMContentLoaded", function () {
        const win = window as Window & { __TS_CREDIT_LOGGED?: boolean };
        if (win.hasOwnProperty("__TS_CREDIT_LOGGED") && win.__TS_CREDIT_LOGGED)
          return;
        win.__TS_CREDIT_LOGGED = true;
        // Noch kompakter, kein Hintergrund, nur ASCII und Farben
        const styleTitle = "color: #ffb347; font-weight: bold;";
        const styleName = "color: #ff0057; font-weight: bold;";
        const styleSlogan = "color: #ffb347; font-weight: bold;";
        const ascii = `%c┌───────────── Talkin' Secret ─────────────┐\n│ Created by %cDave \"The Tank\" Zeplin%c           \n│ %cREAL MUSIK FOR LIKE MINDED.Keep it loud.T.S.%c \n└──────────────────────────────────────────┘`;
        console.log(
          ascii,
          styleTitle,
          styleName,
          styleTitle,
          styleSlogan,
          styleTitle
        );
      });
    </script>
    <!-- Skip to main content link for screen readers -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[9999] focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
      aria-label="Skip to main content"
    >
      Skip to main content
    </a>

    <!-- Main content wrapper -->
    <div>
      <main
        id="main-content"
        tabindex="-1"
        class="min-h-screen h-full w-full focus:outline-none"
        aria-label="Main content"
      >
        <slot />
      </main>
    </div>

    <CookieConsent />

    <footer aria-label="Footer"></footer>
    <!-- Enhanced focus management -->
    <script>
      // Improve keyboard navigation
      document.addEventListener("keydown", function (e) {
        if (e.key === "Tab") {
          document.body.classList.add("keyboard-navigation");
        }
      });

      document.addEventListener("mousedown", function () {
        document.body.classList.remove("keyboard-navigation");
      });

      // Announce page changes to screen readers
      const announcer = document.createElement("div");
      announcer.setAttribute("aria-live", "polite");
      announcer.setAttribute("aria-atomic", "true");
      announcer.className = "sr-only";
      document.body.appendChild(announcer);
    </script>

    <!-- CSS for keyboard navigation -->
    <style>
      .keyboard-navigation *:focus {
        outline: 2px solid #3b82f6 !important;
        outline-offset: 2px !important;
      }

      /* Ensure focus is visible on all interactive elements */
      button:focus,
      a:focus,
      input:focus,
      textarea:focus,
      select:focus,
      [tabindex]:focus {
        outline: 2px solid #3b82f6;
        outline-offset: 2px;
      }
    </style>
  </body>
</html>
